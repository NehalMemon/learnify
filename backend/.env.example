DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN="30d"
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── AWS S3 (CRIT-03) ───────────────────────────────────────
# Required for production file uploads.
# Leave empty for local development (mock mode will be used).
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name

# ─── Redis / BullMQ Event Bus (Sprint 4+) ────────────────────
# Required for async module unlocking. Start the worker:
#   node src/workers/progress.worker.js
REDIS_URL=

# ─── Quiz Session Configuration (Sprint 7+) ──────────────────
# TTL for quiz sessions in Redis (default: 1 hour)
# Should be >= quiz duration + grace period
QUIZ_SESSION_TTL_SEC=3600

# ─── Admin Bootstrap (one-time first admin setup) ──────────────
# OPTION A — HTTP bootstrap endpoint:
#   POST /api/v1/auth/bootstrap with header: x-bootstrap-secret: <value below>
#   Endpoint self-disables once any admin exists.
ADMIN_BOOTSTRAP_SECRET=change-me-to-a-random-secret-string

# ─── Pusher Configuration (Real-time Quiz Updates) ──────────────
# Obtain from: https://pusher.com/
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# ─── AI Integration ──────────────────────────────────────────
GEMINI_API_KEY=

# OPTION B — CLI seed script:
#   npm run seed:admin
# These vars are used by scripts/seed-admin.js:
ADMIN_EMAIL=admin@learnify.pk
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=System Admin

# ─── Database Seed Script (CRIT-01) ───────────────────────────
# Required by scripts/prisma/seed.js for initial admin user.
# Must be at least 8 characters with uppercase, number, and special character.
ADMIN_SEED_PASSWORD=ChangeMeSecure123!

# ─── Google OAuth 2.0 ────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" for a Web Application.
# The frontend sends us the resulting tokenId; we verify it against this ID.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com